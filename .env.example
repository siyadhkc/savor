# =============================================================
#  SAVOR — Environment Variables Reference
#  Copy the relevant section to backend/.env and frontend/.env.development
# =============================================================

# ─────────────────────────────────────────
#  BACKEND  (backend/.env)
# ─────────────────────────────────────────

# Django core
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/savor_db

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Cloudinary (media storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Razorpay (payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Admin superuser (used by build.sh on Render)
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=ChangeMe@1234

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app

# ─────────────────────────────────────────
#  FRONTEND  (frontend/.env.development)
# ─────────────────────────────────────────

# Backend API base URL
VITE_API_URL=http://localhost:8000/api

# Razorpay public key (safe to expose)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
